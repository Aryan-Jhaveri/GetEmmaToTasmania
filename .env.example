# Copy this file to .env and fill in your values for local development.
# In production (GitHub Actions), these are stored as GitHub Secrets.

# SerpAPI — https://serpapi.com
# Free tier: 250 searches/month, no credit card required
# Register → Dashboard → copy your "Private API Key"
SERPAPI_KEY=your_serpapi_key_here

# Google Sheets — paste the entire contents of your service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Sheet ID — the long string in the Sheet URL between /d/ and /edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Gmail SMTP — use an App Password, NOT your regular Gmail password
# Generate at: Google Account > Security > App Passwords
GMAIL_ADDRESS=youremail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
